# ============================================
# 播客协作系统 - 环境变量配置模板
# ============================================
# 复制此文件为 .env 并根据实际情况修改

# ============================================
# MySQL 数据库配置
# ============================================
# MySQL root 用户密码（至少8位）
MYSQL_ROOT_PASSWORD=podcast_root_2024

# ============================================
# MinIO 对象存储配置
# ============================================
# MinIO 根用户（至少3位）
MINIO_ROOT_USER=minioadmin
# MinIO 根密码（至少8位）
MINIO_ROOT_PASSWORD=minioadmin123

# ============================================
# JWT 密钥配置（生产环境必须修改为随机长字符串！
# ============================================
# 至少 256 位（32字符以上）的随机字符串
JWT_SECRET=podcast_collab_jwt_secret_key_2024_very_long_string_please_change

# ============================================
# 可选配置
# ============================================
# 时区设置
TZ=Asia/Shanghai

# =====================================
# Docker 构建忽略文件
# 指定构建时不需要复制到镜像中的文件和目录
# =====================================

# 依赖目录
node_modules/

# 构建产物目录
dist/
build/

# 后端构建目录
backend/target/
backend/.mvn/

# 版本控制
.git/
.gitignore
.gitattributes

# 文档文件
*.md
README*
CHANGELOG*
LICENSE*

# 编辑器和 IDE 文件
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db
ehthumbs.db

# 环境变量文件
.env
.env.local
.env.*.local
*.local

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试和覆盖率
coverage/
.nyc_output/
*.lcov

# 临时文件
tmp/
temp/
.cache/
.parcel-cache/
.eslintcache

# Docker 相关
docker-compose.override.yml
Dockerfile.*
.dockerignore

# 本地配置
.vscode/
.idea/
*.iml
